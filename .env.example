# CMBAgent Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# You only need ONE provider to get started.
# Alternatively, skip this section and configure providers via the Settings UI
# (gear icon in the top bar). UI-set credentials take priority over .env values.

# --- OpenAI ---
OPENAI_API_KEY="your-openai-api-key-here"
# OPENAI_ORGANIZATION="org-..."                # optional: organization ID

# --- Anthropic ---
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# --- Google Gemini ---
GEMINI_API_KEY="your-gemini-api-key-here"
# GOOGLE_CLOUD_PROJECT="my-gcp-project"        # optional: for Vertex AI

# --- Mistral ---
MISTRAL_API_KEY="your-mistral-api-key-here"

# --- Azure OpenAI (overrides OpenAI for gpt-* models when configured) ---
AZURE_OPENAI_API_KEY="your-azure-openai-api-key-here"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT="your-deployment-name"             # optional: default deployment
AZURE_OPENAI_API_VERSION="2024-12-01-preview"              # optional
# AZURE_OPENAI_DEPLOYMENT_MAP='{"gpt-4o": "my-gpt4o"}'    # optional: JSON model->deployment map
# AZURE_OPENAI_VERIFY_SSL="true"                           # set "false" for self-signed certs

# --- AWS Bedrock (requires pip install mars_cmbagent[aws]) ---
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_DEFAULT_REGION="us-east-1"
# AWS_SESSION_TOKEN=""                                     # optional: for STS temp credentials
# AWS_PROFILE="default"                                    # optional: named profile from ~/.aws/credentials

# --- Perplexity (for AI search agent) ---
PERPLEXITY_API_KEY="your-perplexity-api-key-here"

# =============================================================================
# Credential Vault Encryption
# =============================================================================
# Key used to encrypt API credentials stored via the Settings UI.
# Generate with: openssl rand -base64 32
# If not set, falls back to a machine-specific key (hostname + install path).
# Set this in production for portable, secure credential storage.
# MARS_CREDENTIAL_KEY="your-base64-key-here"

# =============================================================================
# Work Directory Configuration
# =============================================================================

# Root directory for all task outputs, logs, and session data
# Default: ~/Desktop/cmbdir
#
# Directory structure:
#   {CMBAGENT_DEFAULT_WORK_DIR}/
#   └── sessions/
#       └── {session_id}/
#           ├── session.log              # Complete audit trail
#           └── tasks/
#               └── {task_id}/
#                   ├── logs/
#                   │   ├── run.log      # Infrastructure events
#                   │   └── console_output.log
#                   ├── cost/            # Cost reports
#                   ├── data/            # Task data
#                   └── ...
CMBAGENT_DEFAULT_WORK_DIR="~/Desktop/cmbdir"

# Frontend work directory (must have NEXT_PUBLIC_ prefix for Next.js)
# Should match CMBAGENT_DEFAULT_WORK_DIR to ensure consistency
NEXT_PUBLIC_CMBAGENT_WORK_DIR="~/Desktop/cmbdir"

# =============================================================================
# Backend Configuration
# =============================================================================

# Application title
CMBAGENT_APP_TITLE="CMBAgent API"

# Application version
CMBAGENT_APP_VERSION="1.0.0"

# CORS allowed origins (comma-separated)
# Default: http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004
CMBAGENT_CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005"

# Maximum file upload size (MB)
CMBAGENT_MAX_FILE_SIZE_MB="10"

# Debug mode (true/false)
CMBAGENT_DEBUG="false"

# Force-disable cosmology RAG agents (true/false).
# When true, cmbagent will never scan cmbagent/agents/rag_agents/, never
# build vector stores, and never register RAG handoffs — regardless of
# what internal callers request. Leave true for PaperPulse and any
# non-cosmology deployment.
CMBAGENT_DISABLE_RAG="true"

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL="INFO"

# Use JSON format for console output (true/false)
LOG_JSON="false"

# Backend system log file location (optional - overrides default)
# Default: {CMBAGENT_DEFAULT_WORK_DIR}/logs/backend.log
# LOG_FILE="/custom/path/to/backend.log"

# =============================================================================
# Database Configuration
# =============================================================================

# Database URL (optional - overrides default location)
# Default: SQLite in {CMBAGENT_DEFAULT_WORK_DIR}/database/cmbagent.db
# Leave commented to use default location in work directory
# CMBAGENT_DATABASE_URL="sqlite:///${HOME}/custom/path/cmbagent.db"

# For PostgreSQL (production):
# CMBAGENT_DATABASE_URL="postgresql://user:password@localhost:5432/cmbagent"

# For MySQL:
# CMBAGENT_DATABASE_URL="mysql+pymysql://user:password@localhost:3306/cmbagent"

# Backend HTTP port. Must match NEXT_PUBLIC_API_URL in frontend/.env.local.
PORT=8000