# MARS-PaperPulse Frontend Environment Variables
# Copy this file to .env.local and update the values as needed.

# Backend API URL
# Must match PORT in root .env (default: 8000)
# For remote access: http://<server-ip>:<PORT>
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (derived from API URL if not set)
# Only override if your WS endpoint uses a different host/port than the API.
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Work directory for task outputs and logs
# Must match CMBAGENT_DEFAULT_WORK_DIR in root .env
NEXT_PUBLIC_CMBAGENT_WORK_DIR=./mars_cmbdir

# Optional: Enable debug mode (verbose console logging)
NEXT_PUBLIC_DEBUG=false

# Framing policy (controls iframe embedding)
# X_FRAME_OPTIONS: SAMEORIGIN (default) | DENY | "" to omit the header
# FRAME_ANCESTORS: CSP frame-ancestors value; defaults to 'self' / 'none' based
# on X_FRAME_OPTIONS. Set explicitly to allow a specific parent, e.g.:
#   FRAME_ANCESTORS='self' https://mars.example.com
# X_FRAME_OPTIONS=SAMEORIGIN
# FRAME_ANCESTORS=
