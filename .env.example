# =============================================================================
# MARS-PaperPulse — Environment Configuration
# =============================================================================
# Copy this file to `.env` and uncomment the section for the LLM provider
# you want to use. You only need ONE provider section filled in.
#
# Tip: the Settings UI (gear icon, top bar) can also store credentials in the
# encrypted vault. UI-set credentials take priority over the values in this
# file, so you can ship a blank `.env` and let users self-onboard.
#
# Resolution order for every per-agent model (highest priority first):
#   1. UI override (per-stage dropdown in StageAdvancedSettings)
#   2. Per-role env var below (CMBAGENT_PLANNER_MODEL, ...)
#   3. workflow_defaults stage entry in mars_cmbagent/config/model_config.yaml
#   4. provider_profiles[<active provider>].all_roles_default (single knob)
#   5. global_defaults from the same YAML
# =============================================================================


# =============================================================================
#                            1. PICK A PROVIDER
# =============================================================================
# Set CMBAGENT_LLM_PROVIDER to the provider you want every agent to use by
# default. When set, ALL agents/roles in every workflow use that provider's
# `all_roles_default` model unless the YAML stage block, a per-role env var
# below, or the UI overrides it. Leave unset to use auto-detection (whichever
# provider has valid credentials first wins).
#
# Allowed values: azure | openai | aws_bedrock | anthropic | google | mistral
# -----------------------------------------------------------------------------
# CMBAGENT_LLM_PROVIDER="azure"


# =============================================================================
#                            2. PROVIDER CREDENTIALS
# =============================================================================
# Uncomment exactly one block below. Leave the others commented out.
# -----------------------------------------------------------------------------

# --- Azure OpenAI (default for enterprise; gpt-4o for every agent) -----------
# Profile default when CMBAGENT_LLM_PROVIDER=azure: gpt-4o
# AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# AZURE_OPENAI_DEPLOYMENT="your-default-deployment"            # optional
# AZURE_OPENAI_API_VERSION="2024-12-01-preview"                # optional
# AZURE_OPENAI_DEPLOYMENT_MAP='{"gpt-4o": "my-gpt4o-deploy"}'  # optional: model -> deployment
# AZURE_OPENAI_VERIFY_SSL="true"                               # "false" for self-signed certs

# --- AWS Bedrock (Claude Sonnet 4.5 for every agent) -------------------------
# Profile default when CMBAGENT_LLM_PROVIDER=aws_bedrock:
#     bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0
# Requires: pip install mars_cmbagent[aws]
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_DEFAULT_REGION="us-east-1"
# AWS_SESSION_TOKEN=""                                          # optional: STS temp creds
# AWS_PROFILE="default"                                         # optional: named profile

# --- OpenAI ------------------------------------------------------------------
# Profile default when CMBAGENT_LLM_PROVIDER=openai: gpt-4o
# OPENAI_API_KEY="sk-..."
# OPENAI_ORGANIZATION="org-..."                                 # optional

# --- Anthropic (direct API, not Bedrock) ------------------------------------
# Profile default when CMBAGENT_LLM_PROVIDER=anthropic: claude-sonnet-4-20250514
# ANTHROPIC_API_KEY="sk-ant-..."

# --- Google Gemini -----------------------------------------------------------
# Profile default when CMBAGENT_LLM_PROVIDER=google: gemini-2.5-pro
# GEMINI_API_KEY="your-gemini-api-key"
# GOOGLE_CLOUD_PROJECT="my-gcp-project"                         # optional: Vertex AI

# --- Mistral ------------------------------------------------------------------
# Profile default when CMBAGENT_LLM_PROVIDER=mistral: mistral-large-latest
# MISTRAL_API_KEY="your-mistral-api-key"

# --- Perplexity (AI search agent only) ---------------------------------------
# PERPLEXITY_API_KEY="your-perplexity-api-key"


# =============================================================================
#                  3. PER-ROLE MODEL OVERRIDES (OPTIONAL)
# =============================================================================
# If you want to override a single role without touching the YAML, set its
# env var. These win over provider_profiles and YAML, but lose to UI selection.
#
# Example (Azure, but switch the engineer to GPT-5):
#   CMBAGENT_LLM_PROVIDER="azure"
#   CMBAGENT_ENGINEER_MODEL="gpt-5-2025-08-07"
#
# Example (AWS Bedrock, but make the formatter Haiku for speed):
#   CMBAGENT_LLM_PROVIDER="aws_bedrock"
#   CMBAGENT_FORMATTER_MODEL="bedrock/us.anthropic.claude-haiku-4-5-20251001-v1:0"
# -----------------------------------------------------------------------------
# CMBAGENT_DEFAULT_MODEL=""
# CMBAGENT_PLANNER_MODEL=""
# CMBAGENT_PLAN_REVIEWER_MODEL=""
# CMBAGENT_RESEARCHER_MODEL=""
# CMBAGENT_ENGINEER_MODEL=""
# CMBAGENT_ORCHESTRATION_MODEL=""
# CMBAGENT_FORMATTER_MODEL=""
# CMBAGENT_IDEA_MAKER_MODEL=""
# CMBAGENT_IDEA_HATER_MODEL=""


# =============================================================================
#                  4. COMMON RUNTIME FLAGS (workflow behavior)
# =============================================================================
# Force-disable cosmology RAG agents. Leave "true" for PaperPulse / any
# non-cosmology deployment — cmbagent will never scan rag_agents, build vector
# stores, or register RAG handoffs regardless of internal callers.
CMBAGENT_DISABLE_RAG="true"

# Globally disable tool calling on agents. Reserved for non-tool models or
# strict deployments where you only want plain-text responses. Read by
# agent-construction layers; agents that honor the flag skip tool registration.
# CMBAGENT_DISABLE_TOOL_CALLS="false"

# Planning / control loop limits (forwarded to WorkflowConfig.from_env()).
# Raise if your plans need more steps; lower for snappier debugging runs.
# CMBAGENT_MAX_ROUNDS_PLANNING="50"
# CMBAGENT_MAX_ROUNDS_CONTROL="100"
# CMBAGENT_MAX_PLAN_STEPS="3"
# CMBAGENT_MAX_N_ATTEMPTS="3"

# Bedrock read-timeout in seconds. Default 600s; bump for Sonnet on long
# prompts that risk a 60s read timeout from ag2's BedrockClient.
# CMBAGENT_BEDROCK_TIMEOUT="600"


# =============================================================================
#                  5. CREDENTIAL VAULT ENCRYPTION
# =============================================================================
# Key used to encrypt API credentials stored via the Settings UI.
# Generate with: openssl rand -base64 32
# If unset, falls back to a machine-specific key (hostname + install path).
# Set this in production for portable, secure credential storage.
# MARS_CREDENTIAL_KEY="your-base64-key-here"


# =============================================================================
#                  6. WORK DIRECTORY
# =============================================================================
# Root directory for task outputs, logs, and session data.
# Layout: {CMBAGENT_DEFAULT_WORK_DIR}/sessions/{session_id}/tasks/{task_id}/...
CMBAGENT_DEFAULT_WORK_DIR="~/Desktop/cmbdir"
# Mirror the same value to the frontend (Next.js requires the NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_CMBAGENT_WORK_DIR="~/Desktop/cmbdir"


# =============================================================================
#                  7. BACKEND CONFIG
# =============================================================================
CMBAGENT_APP_TITLE="CMBAgent API"
CMBAGENT_APP_VERSION="1.0.0"

# CORS allowed origins (comma-separated). Must include the frontend URL.
CMBAGENT_CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005"

# Max upload size (MB)
CMBAGENT_MAX_FILE_SIZE_MB="10"

# Debug mode (also enables uvicorn auto-reload)
CMBAGENT_DEBUG="false"

# Backend HTTP port. Must match NEXT_PUBLIC_API_URL in frontend/.env.local.
PORT=8000


# =============================================================================
#                  8. LOGGING
# =============================================================================
LOG_LEVEL="INFO"
LOG_JSON="false"
# LOG_FILE="/custom/path/to/backend.log"     # default: {work_dir}/logs/backend.log


# =============================================================================
#                  9. DATABASE
# =============================================================================
# Default: SQLite in {CMBAGENT_DEFAULT_WORK_DIR}/database/cmbagent.db
# CMBAGENT_DATABASE_URL="sqlite:///${HOME}/custom/path/cmbagent.db"
# CMBAGENT_DATABASE_URL="postgresql://user:password@localhost:5432/cmbagent"
# CMBAGENT_DATABASE_URL="mysql+pymysql://user:password@localhost:3306/cmbagent"
